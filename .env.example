# DiffusionGemma demo — example environment.
#
# Copy to ".env" (in the repo root):   cp .env.example .env
# It is auto-loaded at startup on every entry path:
#     uv run dlm        (CLI)
#     uvicorn app.server:app            (ASGI)
# Precedence:  CLI flag  >  real exported env var  >  .env file  >  built-in default.
# (So an already-exported shell variable is NEVER overwritten by this file.)
# Mock mode needs NONE of these (it runs with zero config).
#
# Note: the bare names below and their DG_-prefixed aliases both work
#   (e.g. PORT or DG_PORT). HF_TOKEN/HF_HOME are standard Hugging Face vars.

# Hugging Face access token. DiffusionGemma is Apache-2.0 but loading still
# typically requires HF auth / accepting the model terms. Create one at
# https://huggingface.co/settings/tokens  (or run: huggingface-cli login).
HF_TOKEN=

# Where Hugging Face caches downloaded weights. On a cluster, point this at
# fast/large scratch or shared storage so the ~52 GB (bf16) download is reused.
HF_HOME=

# Model repo id to load in real mode.
MODEL_ID=google/diffusiongemma-26B-A4B-it

# Web server bind address and port.
HOST=0.0.0.0
PORT=8000

# Compute precision for real mode: bf16 (~52 GB, fits one 80 GB H100) or fp8
# (~18 GB, needs fp8 kernel support). Ignored in mock mode.
PRECISION=bf16

# 1 = force mock mode (no GPU, no weights, synthetic denoising for preview).
# 0 = real mode (loads the model on a GPU). The --mock CLI flag also forces it.
MOCK=0

# How the real engine produces the reveal:
#   generate = documented model.generate() + reconstructed garbage->text reveal
#              (RELIABLE default; correct text via the official API).
#   custom   = experimental TRUE per-denoising-step capture (needs the model's
#              exact internal API; may be empty/garbled if it doesn't match).
#   auto     = try custom, fall back to generate.
REVEAL_MODE=generate
